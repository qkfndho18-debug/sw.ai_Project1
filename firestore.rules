// StudyBloom — Firestore 보안 규칙 (참고용)
// Firebase 콘솔 > Firestore Database > 규칙(Rules) 탭에 그대로 붙여넣으세요.
//
// 이 프로젝트는 로그인/인증 기능이 없고 학생 이름을 문서 ID로 사용하므로,
// 아래 규칙은 "인증 없이도 앱이 동작"하는 것을 우선한 개발용 규칙입니다.
// 같은 이름을 쓰는 다른 사용자가 데이터를 덮어쓸 수 있다는 점을 감안하세요.
// (실 서비스로 발전시킬 경우 Firebase Authentication을 추가하고,
//  request.auth.uid 기반으로 규칙을 좁히는 것을 권장합니다.)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /students/{studentName} {
      allow read, write: if true;

      match /goals/{goalId} {
        allow read, write: if true;
      }

      match /records/{recordId} {
        allow read, write: if true;
      }
    }
  }
}
